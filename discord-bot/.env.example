# Copiez ce fichier en .env et collez votre token (Discord Developer Portal → Bot → Reset Token)
DISCORD_TOKEN=votre_token_ici

# Optionnel : ID du serveur pour enregistrer les commandes slash instantanément (clic droit serveur → Copier l'identifiant du serveur)
# DISCORD_GUILD_ID=123456789012345678

# URL du site Nova Stream (embeds / liens)
NOVA_WEBSITE_URL=https://hazeyy5.github.io/nova-stream
NOVA_GITHUB_URL=https://github.com/Hazeyy5/nova-stream
