# Copiez ce fichier en .env
DISCORD_TOKEN=votre_token_ici

# ID du serveur Discord Nova Stream (obligatoire — clic droit sur l'icône du serveur → Copier l'identifiant du serveur)
DISCORD_GUILD_ID=123456789012345678

# Pour les annonces CI (#mises-a-jour) — ajoutez aussi ces secrets dans GitHub Actions :
#   DISCORD_BOT_TOKEN (= DISCORD_TOKEN)
#   DISCORD_GUILD_ID

NOVA_WEBSITE_URL=https://hazeyy5.github.io/nova-stream
NOVA_GITHUB_URL=https://github.com/Hazeyy5/nova-stream
