{
  "name": "nova-stream",
  "version": "0.6.0",
  "description": "Application de streaming — alternative légère à Streamlabs OBS",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "start": "electron-vite preview",
    "sync-config": "node scripts/sync-web-config.mjs",
    "dist:win": "npm run build && electron-builder --win --publish never",
  "dist:win:publish": "npm run build && electron-builder --win --publish always",
    "dist": "npm run build && electron-builder"
  },
  "dependencies": {
    "ffmpeg-static": "^5.2.0",
    "native-audio-node": "^0.3.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tmi.js": "^1.8.5"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "typescript": "^5.7.2",
    "vite": "^5.4.11"
  }
}
